{
  "manifest_version": 3,
  "name": "LocalTCP",
  "version": "1.0.0",
  "description": "Your browser can finally talk with local TCP.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [],
  "sockets": {
    "tcp": {
      "connect": "*:*"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "https://*/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}